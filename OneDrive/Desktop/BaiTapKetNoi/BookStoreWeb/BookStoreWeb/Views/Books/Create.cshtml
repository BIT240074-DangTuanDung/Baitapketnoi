@model BookStoreWeb.Models.Book

@{
    ViewData["Title"] = "Thêm Sách Mới";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h3 class="card-title mb-0 fs-5">Nhập Thông Tin Sách - Tự Động Lưu Sang SQL</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-bold">Tiêu đề sách</label>
                    <input asp-for="Title" class="form-control" placeholder="nhập tên sách" required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Tác giả</label>
                    <input asp-for="Author" class="form-control" placeholder="Nhập tên tác giả..." required />
                    <span asp-validation-for="Author" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0" required />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Số lượng tồn kho</label>
                        <input asp-for="Stock" type="number" class="form-control" placeholder="0" required />
                        <span asp-validation-for="Stock" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Danh mục sách</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId" required>
                        <option value="">-- Chọn danh mục sách --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Mô tả tóm tắt</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả nội dung sách..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Quay Lại</a>
                    <button type="submit" class="btn btn-success px-4">Bấm Lưu Xuống SQL Server</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}